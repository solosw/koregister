ith `··>⏎··············{copied·?·(⏎················<Check·className=\"h-3.5·w-3.5\"·/>⏎··············)·:·(⏎················<Copy·className=\"h-3.5·w-3.5\"·/>`",{"range":"30431","text":"30432"},"Insert `···········)}⏎`",{"range":"30433","text":"30434"},"Replace `···············<Button·size=\"icon\"·variant=\"ghost\"·className=\"h-7·w-7·text-muted-foreground·hover:text-foreground\"·onClick={(e)·=>·{·e.stopPropagation();·onShowDetail()·}}·title=\"详情\">` with `············<Button⏎··············size=\"icon\"⏎··············variant=\"ghost\"⏎··············className=\"h-7·w-7·text-muted-foreground·hover:text-foreground\"⏎··············onClick={(e)·=>·{⏎················e.stopPropagation();⏎················onShowDetail();⏎··············}}⏎··············title=\"详情\"`",{"range":"30435","text":"30436"},"Insert `········>⏎`",{"range":"30437","text":"30438"},"Replace `···</Button>` with `</Button>⏎`",{"range":"30439","text":"30440"},{"range":"30441","text":"30419"},"Replace `·<Button·size=\"icon\"·variant=\"ghost\"·className=\"h-7·w-7·text-muted-foreground·hover:text-foreground\"·onClick={(e)·=>·{·e.stopPropagation();·onEdit()·}}·title=\"编辑\">` with `size=\"icon\"⏎··············variant=\"ghost\"⏎··············className=\"h-7·w-7·text-muted-foreground·hover:text-foreground\"⏎··············onClick={(e)·=>·{⏎················e.stopPropagation();⏎················onEdit();⏎··············}}⏎··············title=\"编辑\"`",{"range":"30442","text":"30443"},"Replace `····` with `············>⏎`",{"range":"30444","text":"30445"},{"range":"30446","text":"24785"},"Replace `···············` with `⏎············<Button`",{"range":"30447","text":"30448"},"Replace `·<Button·size=\"icon\"·variant=\"ghost\"·className=\"h-7·w-7·text-muted-foreground·hover:text-destructive·transition-colors\"·onClick={(e)·=>·{·e.stopPropagation();·handleDelete()·}}·title=\"删除\">` with `size=\"icon\"⏎··············variant=\"ghost\"⏎··············className=\"h-7·w-7·text-muted-foreground·hover:text-destructive·transition-co