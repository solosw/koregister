"},{"alt":"36995"},{"range":"37030","text":"37031"},{"alt":"36998"},{"range":"37032","text":"37033"},{"alt":"37001"},{"range":"37034","text":"37035"},{"alt":"36992"},{"range":"37036","text":"37037"},{"alt":"36995"},{"range":"37038","text":"37039"},{"alt":"36998"},{"range":"37040","text":"37041"},{"alt":"37001"},{"range":"37042","text":"37043"},{"alt":"36992"},{"range":"37044","text":"37045"},{"alt":"36995"},{"range":"37046","text":"37047"},{"alt":"36998"},{"range":"37048","text":"37049"},{"alt":"37001"},{"range":"37050","text":"37051"},{"alt":"36992"},{"range":"37052","text":"37053"},{"alt":"36995"},{"range":"37054","text":"37055"},{"alt":"36998"},{"range":"37056","text":"37057"},{"alt":"37001"},{"range":"37058","text":"37059"},{"alt":"36992"},{"range":"37060","text":"37061"},{"alt":"36995"},{"range":"37062","text":"37063"},{"alt":"36998"},{"range":"37064","text":"37065"},{"alt":"37001"},{"range":"37066","text":"37067"},{"alt":"36992"},{"range":"37068","text":"37069"},{"alt":"36995"},{"range":"37070","text":"37071"},{"alt":"36998"},{"range":"37072","text":"37073"},{"alt":"37001"},{"range":"37074","text":"37075"},"block",[18602,18602]," /* empty */ ",[30642,30642],[4716,4740],"[handleLoginSuccess, isLoggingIn, loginType]",[2133,2579],"{ const exportData = exportAccounts(accounts.map(a => a.id))\n        // 如果不包含凭证，移除敏感信息\n        if (!includeCredentials) {\n          exportData.accounts = exportData.accounts.map(acc => ({\n            ...acc,\n            credentials: {\n              ...acc.credentials,\n              accessToken: '',\n              refreshToken: '',\n              csrfToken: ''\n            }\n          }))\n        }\n        return JSON.stringify(exportData, null, 2) }",[3476,4534],"{ const headers = includeCredentials \n          ? ['邮箱', '昵称', '登录方式', 'RefreshToken', 'ClientId', 'ClientSecret', 'Region']\n          : ['邮箱', '昵称', '登录方式', '订阅类型', '订阅标题', '已用量', '总额度']\n        const rows = accounts.map(acc => includeCredentials \n          ? [\n              acc.email,\n              acc.nickname || '',\n              acc.idp || '',\n              acc.credentials?.refreshToken || '',\n              acc.credentials?.clientId || '',\n              acc.credentials?.clientSecret || '',\n              acc.credentials?.region || 'us-east-1'\n            ]\n          : [\n              acc.email,\n              acc.nickname || '',\n              acc.idp || '',\n              acc.subscription?.type || '',\n              acc.subscription?.title || '',\n              String(acc.usage?.current ?? ''),\n              String(acc.usage?.limit ?? '')\n            ]\n        )\n        // 添加 BOM 以支持 Excel 中文\n        return '\\ufeff' + [headers, ...rows].map(row => \n          row.map(cell => `\"${String(cell).replace(/\"/g, '\"\"')}\"`).join(',')\n        ).join('\\n') }",[3476,4534],[642,652],"[filename, loadContent]","&quot;",[26179,26210],"\n            - 勾选&quot;手动验证码\"后，可只填写 ","&ldquo;",[26179,26210],"\n            - 勾选&ldquo;手动验证码\"后，可只填写 ","&#34;",[26179,26210],"\n            - 勾选&#34;手动验证码\"后，可只填写 ","&rdquo;",[26179,26210],"\n            - 勾选&rdquo;手动验证码\"后，可只填写 ",[26179,26210],"\n            - 勾选\"手动验证码&quot;后，可只填写 ",[26179,26210],"\n            - 勾选\"手动验证码&ldquo;后，可只填写 ",[26179,26210],"\n            - 勾选\"手动验证码&#34;后，可只填写 ",[26179,26210],"\n            - 勾选\"手动验证码&rdquo;后，可只填写 ",[26365,26395],": 导入时自动检测已存在的账号，显示&quot;已存在\"状态并跳过注册",[26365,26395],": 导入时自动检测已存在的账号，显示&ldquo;已存在\"状态并跳过注册",[26365,26395],": 导入时自动检测已存在的账号，显示&#34;已存在\"状态并跳过注册",[26365,26395],": 导入时自动检测已存在的账号，显示&rdquo;已存在\"状态并跳过注册",[26365,26395],": 导入时自动检测已存在的账号，显示\"已存在&quot;状态并跳过注册",[26365,26395],": 导入时自动检测已存在的账号，显示\"已存在&ldquo;状态并跳过注册",[26365,26395],": 导入时自动检测已存在的账号，显示\"已存在&#34;状态并跳过注册",[26365,26395],": 导入时自动检测已存在的账号，显示\"已存在&rdquo;状态并跳过注册",[26588,26625],"\n            - 点击&quot;激活 Outlook\"可以批量激活邮箱",[26588,26625],"\n            - 点击&ldquo;激活 Outlook\"可以批量激活邮箱",[26588,26625],"\n            - 点击&#34;激活 Outlook\"可以批量激活邮箱",[26588,26625],"\n            - 点击&r